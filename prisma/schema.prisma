generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Purchase {
  id         String   @id @default(cuid())
  date       DateTime
  amountUsdt Float
  btcPrice   Float
  btcAmount  Float
  source     String
  notes      String?
  createdAt  DateTime @default(now())
}
